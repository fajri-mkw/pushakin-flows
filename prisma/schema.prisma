// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "sqlite"
  url       = env("DATABASE_URL")
}

enum Role {
  Admin
  Manager
  Reporter
  PhotographerAudio
  VideographerAudio
  EditorMedia
  EditorWebSocialMedia
  GraphicDesigner
  StreamingOperator
  PodcastOperator
  Reviewer
  PublisherWeb
  PublisherSocialMedia
}

enum TaskStatus {
  pending
  completed
}

enum Stage {
  Perencanaan
  Produksi
  PascaProduksi
  Review
  Publikasi
  Selesai
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String   @default("$2a$10$placeholder") // Hashed password, will be set on creation
  whatsapp  String?
  avatar    String?
  role      Role     @default(Reporter)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  tasksAsAssignee  Task[]
  notifications    Notification[]
  projectsAsManager Project[]

  @@map("users")
}

model Project {
  id              String   @id @default(cuid())
  title           String
  description     String
  requesterUnit   String
  location        String?
  executionTime   String?
  picName         String?
  picWhatsApp     String?
  activityTypes   String   // JSON array
  customActivity  String?
  outputNeeds     String   // JSON array
  customOutput    String?
  currentStage    Int      @default(1)
  managerId       String
  publicToken     String?  @unique // Token for public sharing
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  manager      User           @relation(fields: [managerId], references: [id], onDelete: Cascade)
  tasks        Task[]
  driveFolders DriveFolder[]
  notifications Notification[]

  @@map("projects")
}

model Task {
  id          String     @id @default(cuid())
  role        String
  stage       Int
  status      TaskStatus @default(pending)
  data        String?    // JSON object for link, notes, etc.
  assignedTo  String
  projectId   String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // Relations
  project    Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee   User    @relation(fields: [assignedTo], references: [id], onDelete: Cascade)

  @@map("tasks")
}

model DriveFolder {
  id            String @id @default(cuid())
  folderId      String // raw, revised, final, desain, lainnya
  name          String
  description   String?
  link          String?
  assignedRoles String? // JSON array of role names
  color         String?
  bgColor       String?
  borderColor   String?
  projectId     String

  // Relations
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("drive_folders")
}

model Notification {
  id         String   @id @default(cuid())
  message    String
  projectId  String?
  targetView String   @default("project_detail")
  read       Boolean  @default(false)
  userId     String
  createdAt  DateTime @default(now())

  // Relations
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@map("notifications")
}

model Settings {
  id                    String   @id @default("main")
  driveAutoCreate       Boolean  @default(false)
  driveParentFolderId   String?
  driveSharedDriveId    String? // Shared Drive (Team Drive) ID for storage
  driveServiceAccountKey String? // JSON service account key
  driveApiKey           String?
  maintenanceMode       Boolean  @default(false)
  maintenanceMessage    String?
  updatedAt             DateTime @updatedAt

  @@map("settings")
}
